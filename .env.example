# Patient Registration — env vars
# Copy this file to `.env.local` and fill in real values. Restart `npm run dev`
# after editing. On Vercel, set these in Project Settings → Environment Variables.

# Recipients for submitted form data (PDF attachment)
REGISTRATION_RECIPIENT_1=
REGISTRATION_RECIPIENT_2=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
# Use `onboarding@resend.dev` for testing, or `noreply@your-verified-domain.com` in prod
EMAIL_FROM_ADDRESS=onboarding@resend.dev
