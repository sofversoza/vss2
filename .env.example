# ============================================================================
# Patient Registration — email delivery
# ============================================================================
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# Restart `npm run dev` after changing env vars.
#
# ---------------------------------------------------------------------------
# DEV TESTING SETUP — send to your own email via Resend
# ---------------------------------------------------------------------------
#  1. Sign up at https://resend.com (free, ~1 min, no credit card needed)
#  2. Create an API key at https://resend.com/api-keys
#  3. Set the values below:
#       EMAIL_PROVIDER=resend
#       RESEND_API_KEY=re_XXXXXXXXXXXXXXXX
#       EMAIL_FROM_ADDRESS=onboarding@resend.dev   # Resend's test sender
#       REGISTRATION_RECIPIENT_1=dev.sofverz@gmail.com
#       REGISTRATION_RECIPIENT_2=                  # leave blank in dev
#  4. Submit a form — the PDF will arrive at REGISTRATION_RECIPIENT_1
#
# When ready for production: verify your own domain in Resend, swap
# EMAIL_FROM_ADDRESS to your verified sender (e.g. noreply@vascularsurgerydocs.com),
# and put the two client emails in REGISTRATION_RECIPIENT_1 / _2.
# ============================================================================

# Provider: "console" (logs only + saves PDF to ./tmp/registrations/) or "resend"
EMAIL_PROVIDER=console

# Recipient email addresses for submitted patient registrations.
# These receive a PDF attachment with PHI — must be authorized recipients.
REGISTRATION_RECIPIENT_1=
REGISTRATION_RECIPIENT_2=

# ----- Resend (required if EMAIL_PROVIDER=resend) -----
# Sign a BAA with Resend (HIPAA-eligible plan) before using with real PHI.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=onboarding@resend.dev
